# Large directories not needed for build
node_modules
.git
.expo
data/*
!data/shadow-prompt-pool.json
.superpowers

# Native build caches — EAS regenerates these. android/ alone is 3.4 GB locally.
android
ios

# Local screenshots + scratch — not needed for build
screenshots
tmp
tmp-test
tmp-screenshots
.emulator-screenshots
emulator-screen.png

# Build artifacts
dist
web-build

# Dev files
*.md

# Debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store

# Metro cache
.metro-health-check*

# NOTE: .env.local is intentionally NOT excluded - EAS needs it for EXPO_PUBLIC_* vars
