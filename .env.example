# Animus — Environment Variables
# Copy to .env.local and fill in values. See below for where to get each key.

# REQUIRED — Supabase (get from: Supabase Dashboard > Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OPTIONAL — RevenueCat (get from: RevenueCat Dashboard > API Keys > Public SDK Key)
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_your_key_here

# OPTIONAL — AdMob (get from: Google AdMob Dashboard > Apps > Ad Units)
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=ca-app-pub-xxx/yyy
EXPO_PUBLIC_ADMOB_NATIVE_ID=ca-app-pub-xxx/yyy

# OPTIONAL — Google Sign-In iOS Client ID (get from: GCP Console > APIs & Services > Credentials)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-client-id.apps.googleusercontent.com

# OPTIONAL — Sentry crash reporting (get from: Sentry Dashboard > Settings > Client Keys)
# EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
